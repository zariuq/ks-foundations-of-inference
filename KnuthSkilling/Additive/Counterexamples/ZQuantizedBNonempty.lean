import Mathlib.Data.NNReal.Basic
import KnuthSkilling.Additive.Proofs.GridInduction.Core.Induction.ThetaPrime

namespace KnuthSkilling.Additive.Counterexamples

open Classical
open scoped NNReal

open KnuthSkilling
open KnuthSkillingAlgebra

/-!
# Counterexample: `ZQuantized_chooseőī_if_B_nonempty` can fail even in a commutative additive model

In the additive model `őĪ = ‚ĄĚ‚Č•0` with `op := (+)` and representation `őė = id` on the old őľ-grid,
take the old grid generated by the single atom `1` and choose a new atom `d = 2/3`.

Then:
- `B` is globally nonempty, since `d^3 = 2` is already on the old grid;
- `chooseőī` (in its `B ‚Č† ‚ąÖ` branch) equals the B-statistic `2/3`;
- but `ZQuantized F R (chooseőī ‚Ä¶)` fails because `őė(1) = 1` is not an integer multiple of `2/3`.

So the helper hypothesis `ZQuantized_chooseőī_if_B_nonempty` (used by the current extension theorem
in `.../Core/Induction/ThetaPrime.lean`) is not derivable in general.
-/

namespace ZQuantizedBNonempty

section

private lemma nat_iterate_add_left_eq_mul (x : ‚ĄĚ‚Č•0) : ‚ąÄ n : ‚Ąē,
    Nat.iterate (fun z : ‚ĄĚ‚Č•0 => x + z) n x = ((n + 1 : ‚Ąē) : ‚ĄĚ‚Č•0) * x
  | 0 => by simp
  | n + 1 => by
      have ih := nat_iterate_add_left_eq_mul x n
      have h_step :
          Nat.iterate (fun z : ‚ĄĚ‚Č•0 => x + z) (n + 1) x
            = x + Nat.iterate (fun z : ‚ĄĚ‚Č•0 => x + z) n x := by
        simp [Function.iterate_succ_apply']
      rw [h_step, ih]
      have hcoeff : (((n + 1 : ‚Ąē) : ‚ĄĚ‚Č•0) + 1) = ((n + 2 : ‚Ąē) : ‚ĄĚ‚Č•0) := by
        have hn : (n + 1 + 1 : ‚Ąē) = n + 2 := by omega
        calc
          ((n + 1 : ‚Ąē) : ‚ĄĚ‚Č•0) + 1 = ((n + 1 + 1 : ‚Ąē) : ‚ĄĚ‚Č•0) := by
            simp [Nat.cast_add]
          _ = ((n + 2 : ‚Ąē) : ‚ĄĚ‚Č•0) := by
            simp [hn]
      calc
        x + ((n + 1 : ‚Ąē) : ‚ĄĚ‚Č•0) * x
            = ((n + 1 : ‚Ąē) : ‚ĄĚ‚Č•0) * x + x := by
                simp [add_comm]
        _ = (((n + 1 : ‚Ąē) : ‚ĄĚ‚Č•0) + 1) * x := by
                simp [add_mul, one_mul]
        _ = ((n + 2 : ‚Ąē) : ‚ĄĚ‚Č•0) * x := by
                exact congrArg (fun a : ‚ĄĚ‚Č•0 => a * x) hcoeff

-- A concrete Knuth‚ÄďSkilling algebra: `‚ĄĚ‚Č•0` with `op := (¬∑ + ¬∑)` and `ident := 0`.
-- We keep this `noncomputable` because the underlying `LinearOrder` on `‚ĄĚ` is noncomputable.
noncomputable local instance : KnuthSkillingAlgebra ‚ĄĚ‚Č•0 where
  op := (¬∑ + ¬∑)
  ident := 0
  op_assoc := by intro x y z; simp [add_assoc]
  op_ident_right := by intro x; simp
  op_ident_left := by intro x; simp
  op_strictMono_left := by intro y x‚āĀ x‚āā hx; exact add_lt_add_right hx y
  op_strictMono_right := by intro x y‚āĀ y‚āā hy; exact add_lt_add_left hy x
  ident_le := by intro x; exact bot_le

-- Singleton atom family with atom `1`.
noncomputable def F1 : AtomFamily ‚ĄĚ‚Č•0 1 :=
  singletonAtomFamily (őĪ := ‚ĄĚ‚Č•0) 1 (by
    simp [KnuthSkillingAlgebraBase.ident])

private noncomputable def i0 : Fin 1 := ‚ü®0, by decide‚ü©

private lemma multi1_eq_const (t : Multi 1) : t = fun _ : Fin 1 => t i0 := by
  funext i
  simpa [i0] using congrArg t (Fin.eq_zero i)

private lemma iterate_op_add_eq_mul (x : ‚ĄĚ‚Č•0) : ‚ąÄ n : ‚Ąē, iterate_op x n = (n : ‚ĄĚ‚Č•0) * x
  | 0 => by
      simp [iterate_op, KnuthSkillingAlgebraBase.ident]
  | n + 1 => by
      have ih := iterate_op_add_eq_mul x n
      calc
        iterate_op x (n + 1) = x + iterate_op x n := by
          simp [iterate_op, KnuthSkillingAlgebraBase.op]
        _ = x + (n : ‚ĄĚ‚Č•0) * x := by simp [ih]
        _ = (n : ‚ĄĚ‚Č•0) * x + x := by
              simp [add_comm]
        _ = ((n : ‚ĄĚ‚Č•0) + 1) * x := by
              simp [add_mul, one_mul]
        _ = ((n + 1 : ‚Ąē) : ‚ĄĚ‚Č•0) * x := by
              simp [Nat.cast_add, Nat.cast_one]

private lemma iterate_op_one_eq_natCast (n : ‚Ąē) : iterate_op (1 : ‚ĄĚ‚Č•0) n = (n : ‚ĄĚ‚Č•0) := by
  simp [iterate_op_add_eq_mul]

private lemma mu_F1 (t : Multi 1) : mu F1 t = (t i0 : ‚ĄĚ‚Č•0) := by
  have ht : t = fun _ : Fin 1 => t i0 := multi1_eq_const t
  have h_ident_lt_one : (KnuthSkillingAlgebraBase.ident : ‚ĄĚ‚Č•0) < 1 := by
    simp [KnuthSkillingAlgebraBase.ident]
  calc
    mu F1 t = mu F1 (fun _ : Fin 1 => t i0) := by
      simpa using congrArg (fun r : Multi 1 => mu F1 r) ht
    _ = iterate_op (1 : ‚ĄĚ‚Č•0) (t i0) := by
          simpa [F1] using
            (mu_singleton (őĪ := ‚ĄĚ‚Č•0) (a := (1 : ‚ĄĚ‚Č•0)) (ha := h_ident_lt_one) (n := t i0))
    _ = (t i0 : ‚ĄĚ‚Č•0) := by
          simp [iterate_op_one_eq_natCast]

-- A simple representation on the őľ-grid: `őė_grid(x) = (x : ‚ĄĚ)`.
noncomputable def R1 : MultiGridRep F1 where
  őė_grid := fun x => (x.1 : ‚ĄĚ)
  strictMono := by
    intro x y hxy
    exact_mod_cast hxy
  add := by
    intro r s
    have hőľr : mu F1 r = (r i0 : ‚ĄĚ‚Č•0) := mu_F1 r
    have hőľs : mu F1 s = (s i0 : ‚ĄĚ‚Č•0) := mu_F1 s
    have hőľrs : mu F1 (fun i => r i + s i) = ((r i0 + s i0 : ‚Ąē) : ‚ĄĚ‚Č•0) := by
      simpa using (mu_F1 (fun i => r i + s i))
    change ((mu F1 (fun i => r i + s i) : ‚ĄĚ‚Č•0) : ‚ĄĚ) =
        ((mu F1 r : ‚ĄĚ‚Č•0) : ‚ĄĚ) + ((mu F1 s : ‚ĄĚ‚Č•0) : ‚ĄĚ)
    simp [hőľr, hőľs, hőľrs, Nat.cast_add]
  ident_eq_zero := by
    simp [KnuthSkillingAlgebraBase.ident]

-- New atom: d = 2/3 > 0.
noncomputable def d : ‚ĄĚ‚Č•0 := (2 : ‚ĄĚ‚Č•0) / 3

lemma d_pos : (KnuthSkillingAlgebraBase.ident : ‚ĄĚ‚Č•0) < d := by
  simp [d, KnuthSkillingAlgebraBase.ident]

private lemma chooseőī_eq_two_div_three :
    chooseőī (őĪ := ‚ĄĚ‚Č•0) (hk := (le_rfl : (1 : ‚Ąē) ‚Č• 1)) R1 d d_pos = (2 : ‚ĄĚ) / 3 := by
  classical
  let r2 : Multi 1 := fun _ => 2
  have h_iter : iterate_op d 3 = (3 : ‚ĄĚ‚Č•0) * d := by
    simpa using iterate_op_add_eq_mul d 3
  have h3d : (3 : ‚ĄĚ‚Č•0) * d = (2 : ‚ĄĚ‚Č•0) := by
    ext
    norm_num [d]
  have hr2B : r2 ‚ąą extensionSetB F1 d 3 := by
    simp [extensionSetB, Set.mem_setOf_eq, r2, mu_F1, h_iter, h3d]
  have IH : GridBridge F1 := gridBridge_of_k_eq_one (F := F1)
  have hőīB :
      separationStatistic R1 r2 3 (by decide) =
        chooseőī (őĪ := ‚ĄĚ‚Č•0) (hk := (le_rfl : (1 : ‚Ąē) ‚Č• 1)) R1 d d_pos :=
    chooseőī_B_bound (őĪ := ‚ĄĚ‚Č•0) (hk := (le_rfl : (1 : ‚Ąē) ‚Č• 1)) R1 IH d d_pos r2 3 (by decide) hr2B
  have hstat : separationStatistic R1 r2 3 (by decide) = (2 : ‚ĄĚ) / 3 := by
    simp [separationStatistic, R1, r2, mu_F1]
  -- Convert `separationStatistic = chooseőī` into a concrete evaluation.
  calc
    chooseőī (őĪ := ‚ĄĚ‚Č•0) (hk := (le_rfl : (1 : ‚Ąē) ‚Č• 1)) R1 d d_pos
        = separationStatistic R1 r2 3 (by decide) := by simpa using hőīB.symm
    _ = (2 : ‚ĄĚ) / 3 := hstat

theorem not_ZQuantized_chooseőī_if_B_nonempty_example :
    ¬¨ ZQuantized_chooseőī_if_B_nonempty (őĪ := ‚ĄĚ‚Č•0) (hk := (le_rfl : (1 : ‚Ąē) ‚Č• 1)) R1 d d_pos := by
  intro hZQ_if
  let r2 : Multi 1 := fun _ => 2
  have hB : ‚ąÉ r u, 0 < u ‚ąß r ‚ąą extensionSetB F1 d u := by
    refine ‚ü®r2, 3, by decide, ?_‚ü©
    have h_iter : iterate_op d 3 = (3 : ‚ĄĚ‚Č•0) * d := by
      simpa using iterate_op_add_eq_mul d 3
    have h3d : (3 : ‚ĄĚ‚Č•0) * d = (2 : ‚ĄĚ‚Č•0) := by
      ext
      norm_num [d]
    simp [extensionSetB, Set.mem_setOf_eq, r2, mu_F1, h_iter, h3d]

  have hQZ :
      ZQuantized F1 R1 (chooseőī (őĪ := ‚ĄĚ‚Č•0) (hk := (le_rfl : (1 : ‚Ąē) ‚Č• 1)) R1 d d_pos) :=
    hZQ_if hB

  have hőī :
      chooseőī (őĪ := ‚ĄĚ‚Č•0) (hk := (le_rfl : (1 : ‚Ąē) ‚Č• 1)) R1 d d_pos = (2 : ‚ĄĚ) / 3 :=
    chooseőī_eq_two_div_three

  -- Apply ZQuantized to the old őľ-grid value `őľ(1) = 1`.
  let r1 : Multi 1 := fun _ => 1
  rcases hQZ r1 with ‚ü®m, hm‚ü©
  have hm' : (m : ‚ĄĚ) * ((2 : ‚ĄĚ) / 3) = 1 := by
    -- `őė_grid(őľ(1)) = 1` and `őī = 2/3`.
    have : (m : ‚ĄĚ) * chooseőī (őĪ := ‚ĄĚ‚Č•0) (hk := (le_rfl : (1 : ‚Ąē) ‚Č• 1)) R1 d d_pos = 1 := by
      -- From `hm : őė(őľ(1)) = m*őī`.
      -- Note: `őė(őľ(1)) = 1` in this representation.
      -- Rewrite in the direction needed for `nlinarith`.
      simpa [R1, mu_F1, r1] using hm.symm
    simpa [hőī] using this

  -- But no integer multiple of `2/3` equals `1`.
  have : False := by
    -- Convert to `2*m = 3` in ‚Ą§, hence `2 ‚ą£ 3`, contradiction.
    have h : (2 : ‚ĄĚ) * (m : ‚ĄĚ) = 3 := by
      nlinarith [hm']
    have h' : ((2 : ‚Ą§) : ‚ĄĚ) * (m : ‚ĄĚ) = ((3 : ‚Ą§) : ‚ĄĚ) := by
      simpa using h
    have h'' : ((2 * m : ‚Ą§) : ‚ĄĚ) = ((3 : ‚Ą§) : ‚ĄĚ) := by
      simpa [Int.cast_mul] using h'
    have hm_int : (2 * m : ‚Ą§) = 3 := Int.cast_inj.mp h''
    have hdiv : (2 : ‚Ą§) ‚ą£ (3 : ‚Ą§) := by
      refine ‚ü®m, ?_‚ü©
      simpa [mul_comm, mul_left_comm, mul_assoc] using hm_int.symm
    have hnot : ¬¨ (2 : ‚Ą§) ‚ą£ (3 : ‚Ą§) := by decide
    exact hnot hdiv
  exact this

end

end ZQuantizedBNonempty

end KnuthSkilling.Additive.Counterexamples
